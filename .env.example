# Copy to .env and fill in real values for local development. spring-dotenv loads this
# file into the Spring Environment automatically at startup - no shell exports needed.
# .env itself is gitignored; only this template is committed.

DB_URL=jdbc:mysql://localhost:3306/guentours?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
DB_USERNAME=guentours
DB_PASSWORD=guentours

APP_JWT_SECRET=ZGV2LW9ubHktc2VjcmV0LWRvLW5vdC11c2UtaW4tcHJvZHVjdGlvbi1wbGVhc2U=
APP_JWT_EXPIRATION_MINUTES=60

# SMTP relay. For a real server use e.g. host/port 587 and MAIL_ENCRYPTION=tls (STARTTLS) or
# port 465 and MAIL_ENCRYPTION=ssl. SMTP AUTH turns on automatically when MAIL_USERNAME is set.
# Leave MAIL_ENCRYPTION empty and MAIL_USERNAME blank for a local dev relay (Mailhog/GreenMail).
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_TIMEOUT_MS=8000
# Envelope "from" address; defaults to MAIL_USERNAME when left blank.
MAIL_FROM=

# Fixed non-refundable reservation fee for "reserve & pay later" (in the booking currency, not deducted from the total).
APP_PAYMENT_RESERVATION_FEE=5000
APP_COMMISSION_FLIGHT_FEE_AMOUNT=15
APP_COMMISSION_HOTEL_FEE_AMOUNT=15
APP_BOOKING_EXPIRY_CHECK_INTERVAL_MS=300000

# Default super-admin seeded on first boot - change the password before going to production.
APP_ADMIN_SEED_ENABLED=true
APP_ADMIN_EMAIL=admin@guentours.com
APP_ADMIN_PASSWORD=ChangeMe123!
APP_ADMIN_FULL_NAME=Super Admin

TRAVELOPRO_ENABLED=true
TRAVELOPRO_MOCK_MODE=true
TRAVELOPRO_BASE_URL=
TRAVELOPRO_API_KEY=
TRAVELOPRO_API_SECRET=
TRAVELOPRO_USERNAME=
TRAVELOPRO_PASSWORD=
TRAVELOPRO_ACCESS_MODE=Test
TRAVELOPRO_CLIENT_IP=127.0.0.1

SABRE_ENABLED=true
SABRE_MOCK_MODE=true
# Sandbox (Dev Studio / CERT): https://api.cert.platform.sabre.com - Production: https://api.platform.sabre.com (default)
SABRE_BASE_URL=https://api.cert.platform.sabre.com
SABRE_API_KEY=
SABRE_API_SECRET=
# Sabre v3 auth uses the password grant: agency username like xxxx-DEVCENTER-EXT + password.
SABRE_USERNAME=
SABRE_PASSWORD=
SABRE_PSEUDO_CITY_CODE=

TRAVELPORT_ENABLED=true
TRAVELPORT_MOCK_MODE=true
# API host, e.g. pre-prod https://api.pp.travelport.com/11 (default) - production https://api.travelport.com/11
TRAVELPORT_BASE_URL=
TRAVELPORT_API_KEY=
TRAVELPORT_API_SECRET=
# Travelport JSON API OAuth password grant + branch scope header.
TRAVELPORT_USERNAME=
TRAVELPORT_PASSWORD=
# OAuth token endpoint (defaults to https://oauth.pp.travelport.com/oauth/oauth20/token when blank).
TRAVELPORT_TOKEN_URL=
TRAVELPORT_ACCESS_GROUP=
# Travelport PCC (branch), sent as the TVP-PCC-Core header, e.g. DU7_1G.
TRAVELPORT_PCC=

REFERENCE_DATA_SYNC_INTERVAL_MS=2592000000
REFERENCE_DATA_SYNC_INITIAL_DELAY_MS=0

SERVER_PORT=8080
